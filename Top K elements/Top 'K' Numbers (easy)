using namespace std;

#include <algorithm>
#include <iostream>
#include <queue>
#include <vector>

class Solution {
public:
  vector<int> findKLargestNumbers(const vector<int>& nums, int k) {
    vector<int> minHeap(nums.begin(), nums.begin() + k);
    make_heap(minHeap.begin(), minHeap.end(), greater());
    for(int i = k; i < nums.size(); i++){
      if(minHeap.front() < nums[i]){
        pop_heap(minHeap.begin(), minHeap.end(), greater());
        minHeap.pop_back();
        minHeap.push_back(nums[i]);
      }
    }
    return minHeap;
  }
};
