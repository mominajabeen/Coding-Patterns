using namespace std;

#include <iostream>
#include <queue>
#include <unordered_map>
#include <vector>

class Solution {
  struct valueCompar{
    char operator()(const pair<int, int> &x, const pair<int, int> & y){
      return x.second > y.second;
    }
  };
public:
  vector<int> findTopKFrequentNumbers(const vector<int> &nums, int k) {
    unordered_map<int, int> freqMap;
    // find the frequency of each number in nums
    for(int num : nums){
      freqMap[num]++;
    }

    priority_queue<pair<int, int>, vector<pair<int, int>>, valueCompar> minHeap;
    // go through all numbers in freqMap and push them in queue
    
    for(auto entry : freqMap){
      minHeap.push(entry);
      // if size of minHeap is greater than k, pop element with minimum frequency
      // i.e smallest top number
      if(minHeap.size() > k){
        minHeap.pop();
      }
    }
    // create a list of top k numbers
    vector<int> topNumbers;
    while(!minHeap.empty()){
      topNumbers.push_back(minHeap.top().first);
      minHeap.pop();
    }
    return topNumbers;
  }
};
