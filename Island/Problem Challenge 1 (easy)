class Solution:
  def findIslandPerimeter(self, matrix):
    self.matrix = matrix
    self.rows = len(matrix)
    self.cols = len(matrix[0])
    self.visited = [[False for i in range(self.cols)] for j in range(self.rows)]

    for i in range(self.rows):
      for j in range(self.cols):
        if(self.matrix[i][j] == 1 and not self.visited[i][j]):
          return self.dfs(i, j)
    return 0
  
  def dfs(self, x, y):
    if(x < 0 or x >= self.rows or y < 0 or y >= self.cols):
      return 1
    if(self.matrix[x][y] == 0): return 1
    if(self.visited[x][y]): return 0

    self.visited[x][y] = True

    edgeCount = 0
    edgeCount += self.dfs(x + 1, y)
    edgeCount += self.dfs(x - 1, y)
    edgeCount += self.dfs(x, y + 1)
    edgeCount += self.dfs(x, y - 1)

    return edgeCount
