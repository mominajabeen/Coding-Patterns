#include <iostream>
#include <vector>
#include <algorithm>

class Solution {
public:
    int findLongestChain(std::vector<std::vector<int>>& pairs) {
        std::sort(pairs.begin(), pairs.end(), [](const std::vector<int>& a, const std::vector<int>& b){
            return a[1] < b[1];
        });

    int currentEnd = INT_MIN;
    int chainCount = 0;

    for(auto & pair : pairs){
        if(pair[0] > currentEnd){
            chainCount++;
            currentEnd = pair[1];
        }
    }
    return chainCount;
    }
};

