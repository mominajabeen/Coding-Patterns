#include <iostream>
#include <vector>

using namespace std;

class Solution {
  public:
    vector<vector<int>> flipAndInvertImage(vector<vector<int>> arr) {
      int s = arr[0].size();
      for(int row = 0; row < arr.size(); row++){
        for(int col = 0; col < (s + 1) / 2; col++){
          int temp = arr[row][col] ^ 1;
          arr[row][col] = arr[row][s - col - 1] ^ 1;
          arr[row][s - col - 1] = temp;
        }
      }
      return arr;
    }
};
