using namespace std;

#include <iostream>
#include <vector>

class Solution {
public:
  vector<int> findSingleNumbers(vector<int> &nums) {
    int n1xn2 = 0;
    for(int num : nums){
      n1xn2 ^= num;
    }
    int rightMostSetBit = 1;
    while((rightMostSetBit & n1xn2) == 0){
      rightMostSetBit = rightMostSetBit << 1;
    }
    int num1 = 0, num2 = 0;
    for(int num : nums){
      if((rightMostSetBit & num) != 0)
        num1 ^= num;
      else
        num2 ^= num;
    }
    return vector<int>{num1, num2};
  }
};
